
{
  "entities": {
    "AppUser": {
      "title": "AppUser",
      "description": "Represents a user of the portal (Admin or Client).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "ClientProfile": {
      "title": "ClientProfile",
      "description": "Additional details for a client user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "companyName": { "type": "string" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["userId", "companyName"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a software project assigned to a client.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "clientId": { "type": "string" },
        "progress": { "type": "number" },
        "status": { "type": "string", "enum": ["Not Started", "In Progress", "Completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "clientId", "progress", "status"]
    },
    "ProjectUpdate": {
      "title": "ProjectUpdate",
      "description": "A daily log or status update for a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "message": { "type": "string" }
      },
      "required": ["id", "projectId", "date", "message"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Financial record of a transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientId", "amount", "status", "date"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A real-time message in a project chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "senderId": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "senderId", "message", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{uid}", "definition": { "entityName": "AppUser", "description": "Global user roles and details." } },
      { "path": "/clients/{uid}", "definition": { "entityName": "ClientProfile", "description": "Extended profile for clients." } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project", "description": "Software project records." } },
      { "path": "/projects/{projectId}/updates/{updateId}", "definition": { "entityName": "ProjectUpdate", "description": "Subcollection for project logs." } },
      { "path": "/payments/{paymentId}", "definition": { "entityName": "Payment", "description": "Admin-only financial ledger." } },
      { "path": "/messages/{messageId}", "definition": { "entityName": "ChatMessage", "description": "Centralized chat messages." } }
    ]
  }
}
