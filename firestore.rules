
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') || 
        request.auth.token.email == 'venkateshchop14@gmail.com'
      );
    }

    function isClient(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Users & Profiles ---
    match /users/{uid} {
      allow read: if isSignedIn();
      // Allow the root admin to create their profile, or any admin to create others
      allow create: if isSignedIn() && (request.auth.token.email == 'venkateshchop14@gmail.com' || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    match /clients/{uid} {
      allow read: if isClient(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
      
      match /updates/{updateId} {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
      allow list, get: if false; 
    }

    // --- Messages ---
    match /messages/{messageId} {
      allow create: if isSignedIn();
      allow list, get: if isAdmin() || (isSignedIn() && (resource.data.senderId == request.auth.uid || request.auth.uid == get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientId));
      allow list: if isAdmin() || isSignedIn(); 
    }

    // --- Inquiries (Lead Capture) ---
    match /inquiries/{id} {
      allow create: if true; // Public lead capture
      allow read, update, delete: if isAdmin();
    }

    // --- Original Content Rules ---
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /portfolioEntries/{id} { allow read: if true; allow write: if isAdmin(); }
    match /clientFeedback/{id} { allow read: if true; allow write: if isAdmin(); }
    match /blogPosts/{id} { allow read: if true; allow write: if isAdmin(); }
    match /roles_admin/{uid} { allow get: if isSignedIn() && request.auth.uid == uid; }
  }
}
