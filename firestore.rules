
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'venkateshchop14@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isClient(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Users & Profiles ---
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.token.email == 'venkateshchop14@gmail.com' || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    match /clients/{uid} {
      allow read: if isClient(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow list: if isAdmin() || isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
      
      match /updates/{updateId} {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid);
        allow write: if isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid);
        allow create: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == request.auth.uid);
      }
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
    }

    // --- Inquiries (Lead Capture) ---
    match /inquiries/{id} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    // --- Static Content Rules ---
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /portfolioEntries/{id} { allow read: if true; allow write: if isAdmin(); }
    match /blogPosts/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
